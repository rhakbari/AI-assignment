# ---- Local development (default) ----
# Local SQLite file (path is relative to prisma/schema.prisma -> prisma/dev.db).
# No external service required.
DATABASE_URL="file:./dev.db"

# Secret used to sign session cookies (HS256 JWT). Use any long random string.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET="dev-only-change-me-to-a-long-random-string-please-32+"

# ---- Production (Vercel + Turso/libSQL) ----
# Vercel's filesystem is ephemeral, so local SQLite will not persist there.
# Create a free Turso database (https://turso.tech) and set these two vars in
# the Vercel project settings. When TURSO_DATABASE_URL is present the app uses
# the libSQL driver adapter instead of the local file.
#   turso db create collab-docs
#   turso db show collab-docs --url
#   turso db tokens create collab-docs
# TURSO_DATABASE_URL="libsql://collab-docs-<org>.turso.io"
# TURSO_AUTH_TOKEN="<token>"
